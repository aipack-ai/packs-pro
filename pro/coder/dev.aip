# Before All

```lua
aip.run.set_label("dev")
local u_common = require("utils_common")

local function append_unique(list, value)
	for _, item in ipairs(list) do
		if item == value then
			return list
		end
	end
	table.insert(list, value)
	return list
end

local function merge_unique(target, source)
	if type(target) ~= "table" then
		target = {}
	end
	if type(source) ~= "table" then
		return target
	end
	for _, value in ipairs(source) do
		append_unique(target, value)
	end
	return target
end

local function pin_dev_status(chat, plan, spec)
	if is_null(chat) or not chat.path then
		aip.run.pin("dev-chat", 2, {
			label = "Dev Chat:",
			content = "(not activated)"
		})	
	else
		local content = chat.path .. "\n(Added to context_globs_post)"
		aip.run.pin("dev-chat", 2, {
			label = "Dev Chat:",
			content = content
		})
	end

	if is_null(plan) or not plan.dir then
		aip.run.pin("dev-plan", 3, {
			label = " Dev Plan:",
			content = "(not activated)"
		})
	else
		local plan_pin_lines = {}
		local dir = plan.dir
		local rules_path = dir .. "/_plan-rules.md"
		-- plan flies
		table.insert(plan_pin_lines, "Plan Files:")
		local existing_plan_files = aip.file.list({ dir .. "/plan-*.md" })
		if type(existing_plan_files) == "table" and #existing_plan_files > 0 then
			for _, file in ipairs(existing_plan_files) do
				table.insert(plan_pin_lines, "- " .. file.path)
			end
			table.insert(plan_pin_lines, "(Added to context_globs_post)")
		else
			table.insert(plan_pin_lines, "- (none yet)")
		end
		
		table.insert(plan_pin_lines, "\nPlan Rules File: " .. rules_path)
		table.insert(plan_pin_lines, "(Added to knowledge_globs_pre)")
				
		-- do the pin
		aip.run.pin("dev-plan", 3, {
			label = " Dev Plan:",
			content = table.concat(plan_pin_lines, "\n")
		})
	end

	if is_null(spec) or not spec.path then
		aip.run.pin("dev-spec", 4, {
			label = " Dev Spec:",
			content = "(not activated)"
		})
	else
		local spec_pin_lines = {}
		table.insert(spec_pin_lines, "Spec Rules File: " .. spec.path)
		table.insert(spec_pin_lines, "(Added to knowledge_globs_post)")
		local spec_context_path = spec.context_path or ((aip.path.parent(spec.path) or ".") .. "/spec.md")
		table.insert(spec_pin_lines, "")
		table.insert(spec_pin_lines, "Spec Context File: " .. spec_context_path)
		table.insert(spec_pin_lines, "(Added to context_globs_post)")
		aip.run.pin("dev-spec", 4, {
			label = " Dev Spec:",
			content = table.concat(spec_pin_lines, "\n")
		})
	end
end

local function default_dev_chat_content()
	return u_common.load_dev_chat_template_content()
end

local function load_plan_rules_from_template()
	local template_path = CTX.AGENT_FILE_DIR .. "/templates/dev/plan/_plan-rules.md"
	local template_file = aip.file.load(template_path)
	if type(template_file) == "table" and type(template_file.content) == "string" and template_file.content ~= "" then
		return template_file.content
	end
	return "# Plan Rules\n\n- Keep plans concise and actionable.\n"
end

local sub_input = inputs and inputs[1] or {}
local agent_config = sub_input.agent_config or {}
local coder_params = sub_input.coder_params or {}

local chat = agent_config.chat
if type(chat) ~= "table" then
	chat = nil
elseif chat.enabled == false then
	chat = nil
end

local plan = agent_config.plan
if type(plan) ~= "table" then
	plan = nil
elseif plan.enabled == false then
	plan = nil
elseif not is_null(plan._resolve_err) and plan._resolve_err ~= "" then
	aip.run.pin("dev-plan", 3, {
		label = " Dev Plan:",
		content = "ERROR: " .. plan._resolve_err
	})
	return aip.flow.before_all_response({
		inputs = {},
		before_all = {
			success = false,
			error_msg = plan._resolve_err
		}
	})
end

local spec = agent_config.spec
if type(spec) ~= "table" then
	spec = nil
elseif spec.enabled == false then
	spec = nil
end

if chat == nil and plan == nil and spec == nil then
	return aip.flow.before_all_response({
		inputs = {},
		before_all = {
			coder_params = {}
		}
	})
end

local next_context_globs_post = coder_params.context_globs_post
if type(next_context_globs_post) ~= "table" then
	next_context_globs_post = {}
end

local next_knowledge_globs_pre = coder_params.knowledge_globs_pre
if type(next_knowledge_globs_pre) ~= "table" then
	next_knowledge_globs_pre = {}
end

local next_knowledge_globs_post = coder_params.knowledge_globs_post
if type(next_knowledge_globs_post) ~= "table" then
	next_knowledge_globs_post = {}
end

if chat ~= nil then
	local path, ensure_err = u_common.ensure_dev_chat_file(chat.path, { seed_content = default_dev_chat_content() })
	if is_null(path) or path == "" then
		return aip.flow.before_all_response({
			inputs = {},
			before_all = {
				success = false,
				error_msg = "Invalid dev.chat.path"
			}
		})
	end

	if ensure_err then
		return aip.flow.before_all_response({
			inputs = {},
			before_all = {
				success = false,
				error_msg = "Failed to initialize dev chat file",
				error_details = ensure_err
			}
		})
	end

	chat.path = path
	append_unique(next_context_globs_post, path)
end

if plan ~= nil then
	local dir, _rules_path, ensure_err = u_common.ensure_dev_plan_file(plan.dir)
	if ensure_err then
		aip.run.pin("dev-plan", 3, {
			label = " Dev Plan:",
			content = "ERROR: " .. ensure_err
		})
		return aip.flow.before_all_response({
			inputs = {},
			before_all = {
				success = false,
				error_msg = "Failed to initialize dev plan rules file",
				error_details = ensure_err
			}
		})
	end
	if is_null(dir) or dir == "" then
		return aip.flow.before_all_response({
			inputs = {},
			before_all = {
				success = false,
				error_msg = "Invalid dev.plan.dir"
			}
		})
	end
	plan.dir = dir

	append_unique(next_knowledge_globs_pre, _rules_path)
	append_unique(next_context_globs_post, dir .. "/plan-*.md")

	local existing_plan_files = aip.file.list({ dir .. "/plan-*.md" })
end

if spec ~= nil then
	local spec_path, spec_context_path, ensure_err = u_common.ensure_dev_spec_file(spec.path)
	if ensure_err then
		aip.run.pin("dev-spec", 4, {
			label = " Dev Spec:",
			content = "ERROR: " .. ensure_err
		})
		return aip.flow.before_all_response({
			inputs = {},
			before_all = {
				success = false,
				error_msg = "Failed to initialize dev spec rules file",
				error_details = ensure_err
			}
		})
	end
	if is_null(spec_path) or spec_path == "" then
		return aip.flow.before_all_response({
			inputs = {},
			before_all = {
				success = false,
				error_msg = "Invalid dev.spec.path"
			}
		})
	end
	spec.path = spec_path
	spec.context_path = spec_context_path

	append_unique(next_knowledge_globs_post, spec_path)
	append_unique(next_context_globs_post, spec_context_path)
end

pin_dev_status(chat, plan, spec)

local updated_coder_params = {}
if #next_context_globs_post > 0 then
	updated_coder_params.context_globs_post = next_context_globs_post
end
if #next_knowledge_globs_pre > 0 then
	updated_coder_params.knowledge_globs_pre = next_knowledge_globs_pre
end
if #next_knowledge_globs_post > 0 then
	updated_coder_params.knowledge_globs_post = next_knowledge_globs_post
end

local dev_content_globs = {}
if chat ~= nil and not is_null(chat.path) and chat.path ~= "" then
	table.insert(dev_content_globs, chat.path)
end
if plan ~= nil and not is_null(plan.dir) and plan.dir ~= "" then
	table.insert(dev_content_globs, plan.dir .. "/plan-*.md")
end
if spec ~= nil and not is_null(spec.context_path) and spec.context_path ~= "" then
	table.insert(dev_content_globs, spec.context_path)
end

return aip.flow.before_all_response({
	inputs = {},
	before_all = {
		coder_params = updated_coder_params,
		agent_result = {
			dev_content_globs = dev_content_globs
		}
	}
})

```

# After All

```lua
return before_all
```
